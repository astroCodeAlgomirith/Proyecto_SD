% ============================================================================
%  caratula.sty - Sistema de diseno de los documentos del Proyecto Final SD
%  (ESCOM-IPN, Equipo 17). Portada + tema completo (encabezados, secciones,
%  cajas, codigo, tablas) inspirado en glab-esimez. Guinda + Plus Jakarta Sans.
%  Compilar con LUALATEX o XELATEX (fuentes en fonts/).
%
%  Uso minimo:
%      \documentclass[11pt]{article}
%      \usepackage{caratula}
%      \definirTitulo{Manual técnico}
%      \begin{document}
%      \portada{Manual\\técnico}{Descripción corta.}
%      \indiceglab
%      \input{manual-tecnico/01-arquitectura}
%      \end{document}
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{caratula}[2026/06/21 Sistema de diseno Proyecto Final SD]

% ----------------------------------------------------------------- base
\RequirePackage[letterpaper,top=2.6cm,bottom=2.6cm,left=2.4cm,right=2.4cm,
                headheight=28pt,headsep=18pt,footskip=32pt]{geometry}
\RequirePackage[spanish,es-noshorthands,es-noindentfirst,es-tabla]{babel}
\RequirePackage{fontspec}
\RequirePackage[table]{xcolor}
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{tabularx}
\RequirePackage{enumitem}
\RequirePackage{parskip}
\RequirePackage{microtype}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{lastpage}
\RequirePackage{caption}
\RequirePackage{listings}
\RequirePackage[most]{tcolorbox}
\RequirePackage{tikz}
\setlength{\emergencystretch}{2.5em}

% ----------------------------------------------------------------- color
\definecolor{guinda50}{HTML}{FBF6F9}
\definecolor{guinda100}{HTML}{F6EAF1}
\definecolor{guinda200}{HTML}{EBD2E0}
\definecolor{guinda300}{HTML}{DAAEC6}
\definecolor{guinda400}{HTML}{C17EA4}
\definecolor{guinda500}{HTML}{A35480}
\definecolor{guinda}{HTML}{6F1D46}      % guinda-700, Pantone 222C
\definecolor{guinda800}{HTML}{5C1839}
\definecolor{guinda900}{HTML}{4A132E}
\definecolor{guinda950}{HTML}{2E0A1C}
\definecolor{stone50}{HTML}{FAFAF9}
\definecolor{stone100}{HTML}{F5F5F4}
\definecolor{stone200}{HTML}{E7E5E4}
\definecolor{stone300}{HTML}{D6D3D1}
\definecolor{stone500}{HTML}{78716C}
\definecolor{stone600}{HTML}{57534E}
\definecolor{stone800}{HTML}{292524}
\definecolor{stone900}{HTML}{1C1917}
\definecolor{ambar}{HTML}{B45309}
\definecolor{esmeralda}{HTML}{047857}
\definecolor{rojo}{HTML}{B91C1C}

% ----------------------------------------------------------------- fuentes
\providecommand{\caratulafontpath}{fonts/}
\defaultfontfeatures{Ligatures=TeX}
\setmainfont{PlusJakartaSans}[
    Path=\caratulafontpath, Extension=.ttf,
    UprightFont=*-Regular, ItalicFont=*-Italic,
    BoldFont=*-Bold, BoldItalicFont=*-BoldItalic]
\setmonofont{JetBrainsMono}[
    Path=\caratulafontpath, Extension=.ttf,
    UprightFont=*-Regular, BoldFont=*-Bold, Scale=0.86]
\newfontfamily\jakarta{PlusJakartaSans-Regular}[Path=\caratulafontpath,Extension=.ttf]
\newfontfamily\jakartamedium{PlusJakartaSans-Medium}[Path=\caratulafontpath,Extension=.ttf]
\newfontfamily\jakartasemibold{PlusJakartaSans-SemiBold}[Path=\caratulafontpath,Extension=.ttf]
\newfontfamily\jakartaextrabold{PlusJakartaSans-ExtraBold}[Path=\caratulafontpath,Extension=.ttf]

% ------------------------- datos del equipo (EDITAR) ------------------------
\def\unidadAprendizaje{Sistemas Distribuidos}
\def\equipoNum{17}
\def\fechaPortada{Junio 2026}
\def\profesorSD{M. en C. Ukranio Coronilla}
\def\integranteUno{Eduardo Alonso Sánchez}            \def\grupoUno{7CM3}
\def\integranteDos{Vania Ivonne Arévalo del Ángel}    \def\grupoDos{7CM4}
\def\integranteTres{Miriam Guadalupe Ramírez Sánchez} \def\grupoTres{7CM2}

% ----------------------------------------------------------------- titulos
\titleformat{\section}
    {\jakartaextrabold\Large\color{guinda950}}
    {\llap{\colorbox{guinda}{\color{white}\jakartaextrabold\normalsize~\thesection~}\hspace{0.6em}}}
    {0pt}{}
\titlespacing*{\section}{0pt}{2.1em}{0.8em}
\titleformat{\subsection}
    {\jakartasemibold\large\color{guinda900}}
    {\textcolor{guinda400}{\thesubsection}}{0.6em}{}
\titlespacing*{\subsection}{0pt}{1.5em}{0.5em}
\titleformat{\subsubsection}
    {\jakartasemibold\normalsize\color{stone800}}
    {\textcolor{guinda400}{\thesubsubsection}}{0.6em}{}

% ----------------------------------------------------------------- header/footer
\newcommand{\docTitle}{}
\newcommand{\definirTitulo}[1]{\renewcommand{\docTitle}{#1}}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{{\jakartasemibold\footnotesize\color{guinda}Banco SD}%
    {\jakartamedium\footnotesize\color{stone500}\ \textperiodcentered\ ESCOM Zacatenco}}
\fancyhead[R]{\jakartamedium\footnotesize\color{stone500}\docTitle}
\renewcommand{\headrule}{\color{guinda200}\hrule width\headwidth height 0.6pt}
\fancyfoot[L]{\jakartamedium\footnotesize\color{stone500}Instituto Polit\'ecnico Nacional}
\fancyfoot[R]{\jakartamedium\footnotesize\color{stone500}%
    P\'agina {\ttfamily\thepage} de {\ttfamily\pageref{LastPage}}}

% ----------------------------------------------------------------- enlaces
\RequirePackage[colorlinks=true,linkcolor=guinda,urlcolor=guinda600,
                citecolor=guinda]{hyperref}

% ----------------------------------------------------------------- listas/tablas
\setlist{itemsep=2pt,topsep=4pt,parsep=0pt}
\setlist[itemize,1]{label=\textcolor{guinda400}{\small\textbullet}}
\renewcommand{\arraystretch}{1.35}
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}m{#1}}
\newcolumntype{C}[1]{>{\centering\arraybackslash}m{#1}}
\newcolumntype{R}[1]{>{\raggedleft\arraybackslash}m{#1}}
\captionsetup{font={small,color=stone600},labelfont={color=guinda}}
\newcommand{\thead}[1]{{\jakartasemibold\small\color{guinda950}#1}}
\newenvironment{tablaglab}[1]
    {\par\addvspace{1em}\centering\small\begin{tabular}{#1}\toprule}
    {\bottomrule\end{tabular}\par\addvspace{1em}}

% ----------------------------------------------------------------- codigo
\lstdefinestyle{glab}{
    basicstyle=\ttfamily\small\color{stone800},
    backgroundcolor=\color{stone50},
    frame=single, rulecolor=\color{stone200}, framerule=0.6pt,
    framesep=8pt, xleftmargin=10pt, xrightmargin=10pt,
    breaklines=true, breakatwhitespace=true,
    postbreak=\mbox{\textcolor{guinda400}{$\hookrightarrow$}\space},
    showstringspaces=false, tabsize=4, columns=fullflexible, keepspaces=true,
    keywordstyle=\color{guinda}\bfseries,
    commentstyle=\color{stone500}\itshape,
    stringstyle=\color{esmeralda},
    aboveskip=1em, belowskip=1em,
    literate={á}{{\'a}}1 {é}{{\'e}}1 {í}{{\'i}}1 {ó}{{\'o}}1 {ú}{{\'u}}1
             {ñ}{{\~n}}1 {Á}{{\'A}}1 {É}{{\'E}}1 {Í}{{\'I}}1 {Ó}{{\'O}}1
             {Ú}{{\'U}}1 {Ñ}{{\~N}}1 {¿}{{?`}}1 {¡}{{!`}}1,
}
\lstset{style=glab}
\lstdefinelanguage{none}{keywords={}}
\newcommand{\codigo}[1]{{\setlength{\fboxsep}{1.5pt}%
    \colorbox{stone100}{\ttfamily\small #1}}}

% ----------------------------------------------------------------- cajas
\newtcolorbox{nota}{enhanced,breakable,colback=guinda50,colframe=guinda50,
    borderline west={2.5pt}{0pt}{guinda},arc=2.5mm,left=10pt,right=10pt,top=8pt,bottom=8pt,
    title={\jakartasemibold\small\textcolor{guinda}{NOTA}},coltitle=guinda,
    attach title to upper={\par\vspace{2pt}},fonttitle=\small}
\newtcolorbox{advertencia}{enhanced,breakable,colback=ambar!6!white,colframe=ambar!6!white,
    borderline west={2.5pt}{0pt}{ambar},arc=2.5mm,left=10pt,right=10pt,top=8pt,bottom=8pt,
    title={\jakartasemibold\small\textcolor{ambar}{IMPORTANTE}},coltitle=ambar,
    attach title to upper={\par\vspace{2pt}},fonttitle=\small}
\newtcolorbox{consejo}{enhanced,breakable,colback=esmeralda!6!white,colframe=esmeralda!6!white,
    borderline west={2.5pt}{0pt}{esmeralda},arc=2.5mm,left=10pt,right=10pt,top=8pt,bottom=8pt,
    title={\jakartasemibold\small\textcolor{esmeralda}{CONSEJO}},coltitle=esmeralda,
    attach title to upper={\par\vspace{2pt}},fonttitle=\small}

% ----------------------------------------------------------------- logo banco
\newcommand{\bancologo}[1][1]{%
  \begin{tikzpicture}[scale=#1,line cap=round,line join=round]
    \fill[guinda,rounded corners=3.2pt] (0,0) rectangle (1.2,1.2);
    \begin{scope}[shift={(0.6,0.6)},white,line width=1.25pt]
      \draw[fill=white,draw=white] (-0.34,0.14)--(0,0.36)--(0.34,0.14)--cycle;
      \draw (-0.30,0.07)--(0.30,0.07);
      \foreach \x in {-0.24,-0.08,0.08,0.24} \draw (\x,0.04)--(\x,-0.22);
      \draw (-0.34,-0.27)--(0.34,-0.27);
    \end{scope}
  \end{tikzpicture}}

% ----------------------------------------------------------------- portada
% #1 = titulo del documento (admite \\)   #2 = descripcion corta
\newcommand{\portada}[2]{%
\begin{titlepage}
\thispagestyle{empty}
\begin{tikzpicture}[remember picture,overlay]
  \fill[guinda950] (current page.south west) rectangle (current page.north east);
  \fill[guinda900,opacity=0.55] ([xshift=-4cm,yshift=5cm]current page.east) circle (7cm);
  \fill[guinda,opacity=0.32]   ([xshift=3cm,yshift=-3cm]current page.north west) circle (6cm);
  \fill[guinda800,opacity=0.30] ([xshift=2cm,yshift=4cm]current page.south east) circle (5.5cm);
  \node[anchor=north west,xshift=2.4cm,yshift=-2.3cm] at (current page.north west) {\bancologo[1.05]};
  \node[anchor=north west,xshift=4.15cm,yshift=-2.52cm,text=white] at (current page.north west)
       {\jakartaextrabold\large Mini Banco};
  \node[anchor=north west,xshift=4.16cm,yshift=-3.08cm,text=guinda300] at (current page.north west)
       {\jakartamedium\footnotesize ESCOM \textperiodcentered\ IPN};
  \node[anchor=west,xshift=2.4cm,yshift=3.0cm,text=guinda300,text width=15cm,align=left]
       at (current page.west)
       {\jakartasemibold\footnotesize\addfontfeatures{LetterSpace=16.0}%
        PROYECTO FINAL \ \textperiodcentered\ \ \MakeUppercase{\unidadAprendizaje}};
  \node[anchor=west,xshift=2.35cm,yshift=0.7cm,text=white,text width=16cm,align=left]
       at (current page.west)
       {\jakartaextrabold\fontsize{36}{42}\selectfont #1};
  \node[anchor=west,xshift=2.4cm,yshift=-2.6cm,text=guinda200,text width=13.8cm,align=left]
       at (current page.west)
       {\jakarta\normalsize #2};
  \node[anchor=south west,xshift=2.4cm,yshift=2.0cm,text width=15.5cm,align=left]
       at (current page.south west)
       {\jakartasemibold\footnotesize\color{guinda300}\addfontfeatures{LetterSpace=16.0}EQUIPO \equipoNum\\[13pt]
        {\jakartamedium\normalsize\color{white}\integranteUno}\ {\footnotesize\color{guinda300}\grupoUno}\\[4pt]
        {\jakartamedium\normalsize\color{white}\integranteDos}\ {\footnotesize\color{guinda300}\grupoDos}\\[4pt]
        {\jakartamedium\normalsize\color{white}\integranteTres}\ {\footnotesize\color{guinda300}\grupoTres}\\[14pt]
        {\jakartamedium\footnotesize\color{guinda400}\profesorSD\ \textperiodcentered\ \fechaPortada}};
\end{tikzpicture}
\end{titlepage}
\setcounter{page}{2}
}

